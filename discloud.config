# Discloud hosting config — https://docs.discloud.com/configurations/discloud.config
# After your first upload, Discloud will give you an APP ID.
# Add it back here as ID=xxxxxxxxxxxxxxxxxx so future `.up`/CLI updates
# redeploy this same app instead of creating a new one.

NAME=Yoran Studios
TYPE=bot
MAIN=main.py
RAM=100
VERSION=latest
AUTORESTART=true
